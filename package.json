{
  "name": "deepwork",
  "version": "1.0.0",
  "description": "Electron deep work session manager for macOS",
  "main": "src/main/index.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "electron-builder --mac",
    "test": "node --test"
  },
  "keywords": [
    "electron",
    "deepwork",
    "productivity",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.deepwork.app",
    "productName": "DeepWork",
    "asarUnpack": [
      "scripts/**"
    ],
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "execa": "^7.2.0",
    "sudo-prompt": "^9.2.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
